<svg xmlns="http://www.w3.org/2000/svg" width="300" height="400" viewBox="0 0 300 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#581C87"/>
      <stop offset="50%" style="stop-color:#7E22CE"/>
      <stop offset="100%" style="stop-color:#D8B4FE"/>
    </linearGradient>
  </defs>
  <rect width="300" height="400" fill="url(#bg)" rx="8"/>
  <circle cx="150" cy="140" r="50" fill="none" stroke="#FCD34D" stroke-width="2" opacity="0.6"/>
  <circle cx="150" cy="140" r="30" fill="#FCD34D" opacity="0.3"/>
  <circle cx="150" cy="140" r="10" fill="#FCD34D" opacity="0.8"/>
  <text x="150" y="240" text-anchor="middle" fill="white" font-family="serif" font-size="22" font-weight="bold">The Power</text>
  <text x="150" y="270" text-anchor="middle" fill="white" font-family="serif" font-size="22" font-weight="bold">of Now</text>
  <text x="150" y="310" text-anchor="middle" fill="#D8B4FE" font-family="sans-serif" font-size="14">Eckhart Tolle</text>
</svg>
